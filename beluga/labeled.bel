% Soprillo (Mini SAX), labelled rules
% lsnip1S/lsnip2S are "snipping" cut variants restricted to eligible terms.
LF lhypS  : o â†’ type = ;
LF lconcS : o â†’ type =
  | linitialS : {h : lhypS A} lconcS A
  | lâŠƒRS      : (lhypS A â†’ lconcS B) â†’ lconcS (A âŠƒ B)
  | lâŠƒL0S     : lhypS A â†’ lhypS (A âŠƒ B) â†’ lconcS B             % atomic âŠƒL
  | lâŠ—R0S     : lhypS A â†’ lhypS B â†’ lconcS (A âŠ— B)             % atomic âŠ—R
  | lâŠ—LS      : (lhypS A â†’ lhypS B â†’ lconcS C) â†’ lhypS (A âŠ— B) â†’ lconcS C
  | lsnip1S   : {D : lconcS A} elig_c D â†’ (lhypS A â†’ lconcS B) â†’ lconcS B
  | lsnip2S   : lconcS A â†’ {E : lhypS A â†’ lconcS B} elig_h E â†’ lconcS B
and
% elig_c D: D is an eligible conclusion (can appear as lsnip1S subject)
LF elig_c : lconcS A â†’ type =
  | elig_c/lâŠƒL0S : {x : lhypS A} {y : lhypS (A âŠƒ B)} elig_c (lâŠƒL0S x y)
and
% elig_h E: E is an eligible hypothesis continuation (can appear as lsnip2S subject)
LF elig_h : (lhypS A â†’ lconcS B) â†’ type =
  | elig_h/lâŠƒL0S    : {y : lhypS (A âŠƒ B)} elig_h (\x. lâŠƒL0S x y)
  | elig_h/lâŠ—R0S/1  : {z : lhypS B} elig_h (\y. lâŠ—R0S (y : lhypS A) z)
  | elig_h/lâŠ—R0S/2  : {y : lhypS A} elig_h (\z. lâŠ—R0S y (z : lhypS B))
  | elig_h/lâŠ—R0S/3  : elig_h (\y. lâŠ—R0S y y)                   % diagonal case
;

% Soprillo extended with explicit cut (for cut-elimination)
% Mirrors lconcS/elig_c/elig_h exactly, adding lcutS-cut.
LF lconcS-cut : o â†’ type =
  | linitialS-cut : {h : lhypS A} lconcS-cut A
  | lâŠƒRS-cut      : (lhypS A â†’ lconcS-cut B) â†’ lconcS-cut (A âŠƒ B)
  | lâŠƒL0S-cut     : lhypS A â†’ lhypS (A âŠƒ B) â†’ lconcS-cut B
  | lâŠ—R0S-cut     : lhypS A â†’ lhypS B â†’ lconcS-cut (A âŠ— B)
  | lâŠ—LS-cut      : (lhypS A â†’ lhypS B â†’ lconcS-cut C) â†’ lhypS (A âŠ— B) â†’ lconcS-cut C
  | lcutS-cut     : lconcS-cut A â†’ (lhypS A â†’ lconcS-cut B) â†’ lconcS-cut B
  | lsnip1S-cut   : {D : lconcS-cut A} elig_c-cut D â†’ (lhypS A â†’ lconcS-cut B) â†’ lconcS-cut B
  | lsnip2S-cut   : lconcS-cut A â†’ {E : lhypS A â†’ lconcS-cut B} elig_h-cut E â†’ lconcS-cut B
and
LF elig_c-cut : lconcS-cut A â†’ type =
  | elig_c/lâŠƒL0S-cut : {x : lhypS A} {y : lhypS (A âŠƒ B)} elig_c-cut (lâŠƒL0S-cut x y)
and
LF elig_h-cut : (lhypS A â†’ lconcS-cut B) â†’ type =
  | elig_h/lâŠƒL0S-cut   : {y : lhypS (A âŠƒ B)} elig_h-cut (\x. lâŠƒL0S-cut x y)
  | elig_h/lâŠ—R0S/1-cut : {z : lhypS B} elig_h-cut (\y. lâŠ—R0S-cut (y : lhypS A) z)
  | elig_h/lâŠ—R0S/2-cut : {y : lhypS A} elig_h-cut (\z. lâŠ—R0S-cut y (z : lhypS B))
  | elig_h/lâŠ—R0S/3-cut : elig_h-cut (\y. lâŠ—R0S-cut y y)
;
